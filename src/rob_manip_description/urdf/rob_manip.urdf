<?xml version="1.0"?>
<robot name="rob_manip">

<!-- ==================== BASE LINK ==================== -->
<link name="base_link">
    <visual>
        <geometry>
            <cylinder length="0.05" radius="0.1"/>
        </geometry>
        <material name="silver">
            <color rgba="0.75 0.75 0.75 1"/>
        </material>
        <origin rpy="0.0 0 0" xyz="0 0 0.025"/>
    </visual>
    <collision>
        <geometry>
            <cylinder length="0.05" radius="0.1"/>
        </geometry>
        <origin rpy="0.0 0 0" xyz="0 0 0.025"/>
    </collision>
    <inertial>
        <mass value="1.0"/>
        <inertia ixx="0.0027" iyy="0.0027" izz="0.005" ixy="0" ixz="0" iyz="0"/>
        <origin rpy="0.0 0 0" xyz="0 0 0.025"/>
    </inertial>
</link>

<!-- Fiksna veza s okolinom -->
<link name="world"/>
<joint name="fixed" type="fixed">
    <parent link="world"/>
    <child link="base_link"/>
</joint>

<!-- ==================== TORSO ==================== -->
<link name="torso">
    <visual>
        <geometry>
            <cylinder length="0.1" radius="0.05"/>
        </geometry>
        <material name="silver">
            <color rgba="0.75 0.75 0.75 1"/>
        </material>
        <origin rpy="0.0 0 0" xyz="0 0 0.05"/>
    </visual>
    <collision>
        <geometry>
            <cylinder length="0.1" radius="0.05"/>
        </geometry>
        <origin rpy="0.0 0 0" xyz="0 0 0.05"/>
    </collision>
    <inertial>
        <mass value="1.0"/>
        <inertia ixx="0.00145" iyy="0.00145" izz="0.00125" ixy="0" ixz="0" iyz="0"/>
        <origin rpy="0.0 0 0" xyz="0 0 0.05"/>
    </inertial>
</link>

<!-- Hip joint: rotacija oko Z osi (yaw) -->
<joint name="hip" type="revolute">
    <axis xyz="0 0 1"/>
    <parent link="base_link"/>
    <child link="torso"/>
    <origin rpy="0 0 0" xyz="0.0 0.0 0.05"/>
    <limit lower="-3.14" upper="3.14" effort="100.0" velocity="3.14"/>
</joint>

<!-- ==================== UPPER ARM ==================== -->
<link name="upper_arm">
    <visual>
        <geometry>
            <cylinder length="0.4" radius="0.05"/>
        </geometry>
        <material name="silver">
            <color rgba="0.75 0.75 0.75 1"/>
        </material>
        <origin rpy="0.0 0 0" xyz="0 0 0.2"/>
    </visual>
    <collision>
        <geometry>
            <cylinder length="0.4" radius="0.05"/>
        </geometry>
        <origin rpy="0.0 0 0" xyz="0 0 0.2"/>
    </collision>
    <inertial>
        <mass value="1.0"/>
        <inertia ixx="0.01396" iyy="0.01396" izz="0.00125" ixy="0" ixz="0" iyz="0"/>
        <origin rpy="0.0 0 0" xyz="0 0 0.2"/>
    </inertial>
</link>

<!-- Shoulder joint: rotacija oko Y osi (pitch) -->
<joint name="shoulder" type="revolute">
    <axis xyz="0 1 0"/>
    <parent link="torso"/>
    <child link="upper_arm"/>
    <origin rpy="0 0 0" xyz="0 0.1 0.05"/>
    <limit lower="-3.14" upper="3.14" effort="100.0" velocity="3.14"/>
</joint>

<!-- ==================== FOREARM ROLL LINK (međulink za lakat) ==================== -->
<link name="forearm_roll_link">
    <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
            <cylinder length="0.01" radius="0.01"/>
        </geometry>
        <material name="silver">
            <color rgba="0.75 0.75 0.75 1"/>
        </material>
    </visual>
    <collision>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
            <cylinder length="0.01" radius="0.01"/>
        </geometry>
    </collision>
    <inertial>
        <mass value="0.05"/>
        <inertia ixx="0.0001" iyy="0.0001" izz="0.0001" ixy="0" ixz="0" iyz="0"/>
    </inertial>
</link>

<!-- Elbow joint: rotacija oko Y osi (pitch) -->
<joint name="elbow" type="revolute">
    <axis xyz="0 1 0"/>
    <parent link="upper_arm"/>
    <child link="forearm_roll_link"/>
    <origin rpy="0 0 0" xyz="0.0 -0.1 0.35"/>
    <limit lower="-3.14" upper="3.14" effort="100.0" velocity="3.14"/>
</joint>

<!-- ==================== LOWER ARM ==================== -->
<link name="lower_arm">
    <visual>
        <geometry>
            <cylinder length="0.4" radius="0.05"/>
        </geometry>
        <material name="silver">
            <color rgba="0.75 0.75 0.75 1"/>
        </material>
        <origin rpy="0.0 0 0" xyz="0 0 0.2"/>
    </visual>
    <collision>
        <geometry>
            <cylinder length="0.4" radius="0.05"/>
        </geometry>
        <origin rpy="0.0 0 0" xyz="0 0 0.2"/>
    </collision>
    <inertial>
        <mass value="1.0"/>
        <inertia ixx="0.01396" iyy="0.01396" izz="0.00125" ixy="0" ixz="0" iyz="0"/>
        <origin rpy="0.0 0 0" xyz="0 0 0.2"/>
    </inertial>
</link>

<!-- Forearm roll joint: rotacija oko Z osi (roll podlaktice) -->
<joint name="forearm_roll" type="revolute">
    <axis xyz="0 0 1"/>
    <parent link="forearm_roll_link"/>
    <child link="lower_arm"/>
    <origin rpy="0 0 0" xyz="0 0 0"/>
    <limit lower="-3.14" upper="3.14" effort="100.0" velocity="3.14"/>
</joint>

<!-- ==================== WRIST ROLL LINK (međulink za zglob) ==================== -->
<link name="wrist_roll_link">
    <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
            <cylinder length="0.01" radius="0.01"/>
        </geometry>
        <material name="silver">
            <color rgba="0.75 0.75 0.75 1"/>
        </material>
    </visual>
    <collision>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
            <cylinder length="0.01" radius="0.01"/>
        </geometry>
    </collision>
    <inertial>
        <mass value="0.05"/>
        <inertia ixx="0.0001" iyy="0.0001" izz="0.0001" ixy="0" ixz="0" iyz="0"/>
    </inertial>
</link>

<!-- Wrist joint: rotacija oko Y osi (pitch zapešća) -->
<joint name="wrist" type="revolute">
    <axis xyz="0 1 0"/>
    <parent link="lower_arm"/>
    <child link="wrist_roll_link"/>
    <origin rpy="0 0 0" xyz="0.0 0.0 0.4"/>
    <limit lower="-3.14" upper="3.14" effort="100.0" velocity="3.14"/>
</joint>

<!-- ==================== HAND ==================== -->
<link name="hand">
    <visual>
        <geometry>
            <box size="0.05 0.05 0.05"/>
        </geometry>
        <material name="silver">
            <color rgba="0.75 0.75 0.75 1"/>
        </material>
        <origin rpy="0.0 0 0" xyz="0 0 0.025"/>
    </visual>
    <collision>
        <geometry>
            <box size="0.05 0.05 0.05"/>
        </geometry>
        <origin rpy="0.0 0 0" xyz="0 0 0.025"/>
    </collision>
    <inertial>
        <mass value="0.5"/>
        <inertia ixx="0.00042" iyy="0.00042" izz="0.00042" ixy="0" ixz="0" iyz="0"/>
        <origin rpy="0.0 0 0" xyz="0 0 0.025"/>
    </inertial>
</link>

<!-- Hand roll joint: rotacija oko Z osi (roll šake) -->
<joint name="hand_roll" type="revolute">
    <axis xyz="0 0 1"/>
    <parent link="wrist_roll_link"/>
    <child link="hand"/>
    <origin rpy="0 0 0" xyz="0 0 0"/>
    <limit lower="-3.14" upper="3.14" effort="100.0" velocity="3.14"/>
</joint>

<!-- ==================== GAZEBO MATERIJALI ==================== -->
<gazebo reference="base_link">
    <material>Gazebo/Chrome</material>
</gazebo>
<gazebo reference="torso">
    <material>Gazebo/Chrome</material>
</gazebo>
<gazebo reference="upper_arm">
    <material>Gazebo/Chrome</material>
</gazebo>
<gazebo reference="forearm_roll_link">
    <material>Gazebo/Chrome</material>
</gazebo>
<gazebo reference="lower_arm">
    <material>Gazebo/Chrome</material>
</gazebo>
<gazebo reference="wrist_roll_link">
    <material>Gazebo/Chrome</material>
</gazebo>
<gazebo reference="hand">
    <material>Gazebo/Chrome</material>
</gazebo>

<!-- ==================== GAZEBO ROS2 CONTROL PLUGIN ==================== -->
<gazebo>
    <plugin filename="gz_ros2_control-system" name="gz_ros2_control::GazeboSimROS2ControlPlugin">
        <parameters>/home/lana/ros2_workspace_Kocis/install/rob_manip_moveit/share/rob_manip_moveit/config/ros2_controllers.yaml</parameters>
    </plugin>
</gazebo>

</robot>
